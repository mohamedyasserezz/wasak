{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/up",
    "restartPolicyType": "ON_FAILURE",
    "preDeployCommand": "php artisan migrate --force && php artisan storage:link"
  }
}
